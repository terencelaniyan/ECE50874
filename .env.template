# Copy this file to .env and fill in real values. 
# Do NOT commit your actual .env file to version control.

# Password for the 'postgres' superuser in the database container
POSTGRES_PASSWORD=

# Full connection string for the backend to reach the database
# Use 'postgres' as the host when running inside Docker Compose
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@postgres:5432/bowlingdb

# Set to 'production' to enable CORS restrictions and other optimizations
APP_ENV=production

# Secret key required for admin-only endpoints (e.g., refresh catalog)
ADMIN_KEY=
