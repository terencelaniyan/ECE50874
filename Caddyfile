# ===========================================================================
# Caddyfile – HTTPS Reverse Proxy Configuration
# ---------------------------------------------------------------------------
# Replace 'yourdomain.com' with your actual domain name. 
# Caddy will automatically handle TLS certificates via Let's Encrypt/ZeroSSL.
# Note: Ports 80 and 443 must be open and reachable from the internet.
# ===========================================================================

yourdomain.com {
    # Forward all traffic to the 'frontend' service on port 80
    reverse_proxy frontend:80
}
